# Streamlit Cloud 배포 시 secrets로 등록 (UI Advanced settings → Secrets에 붙여넣기)
# 또는 로컬에서 .streamlit/secrets.toml 만들어서 테스트

# ============================================================
# 필수
# ============================================================

# Anthropic API 키 (필수 — 없으면 mock 응답)
ANTHROPIC_API_KEY = "sk-ant-..."

# Cloud는 Claude Code CLI 없음 → API 키 모드 강제
FORCE_AUTH_MODE = "api_key"


# ============================================================
# 선택
# ============================================================

# 모델 (기본 opus 권장)
DEFAULT_MODEL = "claude-opus-4-7"

# 외부 동기화 폴더 (Cloud에선 빈 값)
DRIVE_OUTPUT_DIR = ""

# 외부 노하우 폴더 (Cloud에선 빈 값 — 내장 노하우 자동)
SORI_SKILL_DIR = ""

# 작품 저장 위치 (Cloud는 휘발성 — 빈 값이면 ./output/)
STORY_MAKER_OUTPUT = ""
