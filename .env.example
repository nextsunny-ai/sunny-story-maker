# ============================================================
# SUNNY Story Maker V2 — 환경 변수 (Vercel 배포용)
# ============================================================
# 사용법:
#   1) 이 파일을 .env.local로 복사
#   2) 아래 값들을 실제 값으로 채움
#   3) Vercel 배포 시 Vercel.com → Project Settings → Environment Variables
#      에 동일한 키/값을 입력 (NEXT_PUBLIC_ 변수는 그대로, 시크릿은 Server-only)

# ─── Anthropic (필수) ──────────────────────────────────────
# https://console.anthropic.com/settings/keys 에서 발급
# 서버 측에서만 사용 (NEXT_PUBLIC_ 안 붙임)
ANTHROPIC_API_KEY=sk-ant-...

# 사용 모델 (변경 시 시스템 프롬프트 캐시 무효화됨)
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# ─── Supabase (필수) ───────────────────────────────────────
# https://supabase.com/dashboard → 프로젝트 → Project Settings → API
# NEXT_PUBLIC_ prefix는 브라우저에서도 접근 가능 (anon key는 안전)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# 서버 측 전용 service role key (선택 — admin 작업 필요 시)
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── 초대 코드 (필수, 베타 기간) ────────────────────────────
# 신규 가입자가 입력해야 가입 가능
INVITE_CODE=SUNNY2026!

# ─── 외부 동기화 (선택) ────────────────────────────────────
# Google Drive / OneDrive 등에 출력물 자동 백업 폴더 (로컬 dev에서만)
DRIVE_OUTPUT_DIR=
