# Anthropic API 키 (필수) — https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# 사용 모델 (기본 권장)
DEFAULT_MODEL=claude-opus-4-7

# 출력물을 동기화할 외부 폴더 (선택) — Google Drive / OneDrive / Dropbox 등
DRIVE_OUTPUT_DIR=

# 외부 SKILL.md 폴더 (선택) — 작가 본인 SKILL.md를 연결하면 그게 우선 적용됨
# 미설정 시 내장 기본 노하우 사용 (humanizer 6패턴 / Tier 시스템 / 13장르 매뉴얼 등)
SORI_SKILL_DIR=